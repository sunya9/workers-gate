# Copy me: `cp .dev.vars.example .dev.vars`, then fill in your GitHub OAuth
# app's credentials (https://github.com/settings/developers, callback URL
# http://localhost:8787/auth/callback). `.dev.vars` is gitignored;
# `wrangler types` reads it to type the secrets on env.
GITHUB_CLIENT_ID = "replace-me"
GITHUB_CLIENT_SECRET = "replace-me"
COOKIE_SECRET = "replace-me-with-openssl-rand-hex-32"

# Optional: values here override wrangler.jsonc "vars" during `wrangler dev`,
# so you can test against a real org without touching tracked files.
# GITHUB_ORG = "your-real-org"
