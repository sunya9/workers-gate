{
  "name": "workers-gate",
  "version": "0.0.0",
  "description": "Stateless authorization gate for apps on Cloudflare Workers — bring your own provider, no database, cookie signing delegated to jose",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "cloudflare-workers",
    "authorization",
    "oauth2",
    "gate",
    "stateless"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "oxfmt src test examples",
    "fmt:check": "oxfmt --check src test examples",
    "lint": "oxlint src test examples",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "pnpm --filter './examples/*' typecheck"
  },
  "dependencies": {
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
