{
  "name": "workers-gate",
  "version": "0.2.0",
  "description": "Stateless authorization gate for apps on Cloudflare Workers — bring your own provider, no database, cookie signing delegated to jose",
  "keywords": [
    "authorization",
    "cloudflare-workers",
    "gate",
    "oauth2",
    "stateless"
  ],
  "homepage": "https://github.com/sunya9/workers-gate#readme",
  "bugs": {
    "url": "https://github.com/sunya9/workers-gate/issues"
  },
  "license": "MIT",
  "author": "sunya (https://unsweets.net/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunya9/workers-gate.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "pnpm --filter './examples/*' typecheck"
  },
  "dependencies": {
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.72.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0"
}
